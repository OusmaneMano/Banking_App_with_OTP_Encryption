<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.otpreceiverapp">

    <!-- Required for networking -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="OTP Receiver App"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OTPReceiverApp"
        android:networkSecurityConfig="@xml/network_security_config">



        <!-- Launcher Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Other internal activities (no intent filters, so exported not required or should be false) -->
        <activity android:name=".LoginActivity" android:exported="false" />
        <activity android:name=".SpecialCodeActivity" android:exported="false" />
        <activity android:name=".GetOtpActivity" android:exported="false" />

    </application>

</manifest>